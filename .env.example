# ── Supabase ──────────────────────────────────────────────────────────────
# Project Settings → Data API (URL) and Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Service role key — SERVER ONLY. Never expose with NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Stripe ────────────────────────────────────────────────────────────────
# Developers → API keys (use test keys until you go live)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ───────────────────────────────────────────────────────────────────
# Canonical site URL (no trailing slash). Used for OAuth redirects.
# Local: http://localhost:3000  Production: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Vendor queue simulation ───────────────────────────────────────────────
# How many real seconds one "queue minute" takes. Default 2 → an 18 minute
# quoted queue resolves in ~36s so the demo lifecycle is watchable.
SIM_SECONDS_PER_MINUTE=2

# ── Vultr (optional) ──────────────────────────────────────────────────────
# Reserved for wiring real GPU instance provisioning (src/lib/vultr.ts).
# The platform runs fully without it — vendor execution is simulated.
VULTR_API_KEY=
